# Скопируйте в .env и подставьте значения. Файл .env не коммитьте.
#
# Если MySQL/MariaDB на другом сервере (хостинг, VPS), укажите его адрес или имя:
# MYSQL_HOST=db.example.com
# MYSQL_PORT=3306
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=form_user
MYSQL_PASSWORD=
MYSQL_DATABASE=form_app

# Для отладки при ошибке записи в БД (показывать исключение на странице): 1 или 0
# WSGI_DEBUG=0
